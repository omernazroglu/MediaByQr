@model Etkinlik
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Yeni Etkinlik Ekle</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        /* Global Styles & Body */
        body {
            background-color: #f0f2f5;
            font-family: 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            color: #333;
        }

        /* Card Styling */
        .card {
            border: none !important;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

            .card:hover {
                transform: translateY(-5px);
                box-shadow: 0 1rem 3rem rgba(0, 0, 0, 0.1) !important;
            }

        .card-header {
            background: linear-gradient(45deg, #007bff, #0056b3);
            border-bottom: none;
            padding: 1.5rem;
            border-radius: 1rem 1rem 0 0 !important;
        }

            .card-header h3 {
                font-weight: 600;
                letter-spacing: 1px;
            }

        .card-body {
            background-color: #ffffff;
        }

        .card-footer {
            background-color: #f7f9fc !important;
            border-top: 1px solid #e0e0e0;
            padding: 1rem 1.5rem;
        }

            .card-footer a {
                color: #6c757d;
                font-weight: 500;
                transition: color 0.3s ease;
            }

                .card-footer a:hover {
                    color: #495057;
                    text-decoration: underline !important;
                }

        /* Form Elements */
        .form-label {
            color: #495057;
            font-weight: 600 !important;
            margin-bottom: 0.5rem;
        }

        .form-control {
            border-radius: 0.5rem;
            padding: 0.875rem 1rem;
            border: 1px solid #ced4da;
            transition: border-color 0.3s ease, box-shadow 0.3s ease;
        }

            .form-control:focus {
                border-color: #007bff;
                box-shadow: 0 0 0 0.25rem rgba(0, 123, 255, 0.25);
            }

        .btn-primary {
            background: linear-gradient(45deg, #007bff, #0056b3);
            border: none;
            font-weight: 600;
            padding: 0.875rem 1rem;
            border-radius: 0.5rem;
            transition: background 0.3s ease, transform 0.1s ease;
            box-shadow: 0 4px 12px rgba(0, 123, 255, 0.2);
        }

            .btn-primary:hover {
                background: linear-gradient(45deg, #0056b3, #004085);
                transform: translateY(-2px);
            }

            .btn-primary:active {
                transform: translateY(0);
                box-shadow: 0 2px 6px rgba(0, 123, 255, 0.2);
            }

        /* Validation Messages */
        .text-danger {
            font-size: 0.875rem;
            margin-top: 0.25rem;
            display: block;
        }
    </style>
</head>
<body>



    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="card shadow-lg border-0 rounded-4">
                    <div class="card-header bg-primary text-white text-center rounded-top-4">
                        <h3 class="m-0">Yeni Etkinlik Ekle</h3>
                    </div>
                    <div class="card-body p-4">
                        @using (Html.BeginForm("Create", "Etkinlikler", FormMethod.Post))
                        {
                            @Html.AntiForgeryToken()

                            <div class="mb-3">
                                @Html.LabelFor(m => m.EtkinlikAdi, new { @class = "form-label fw-bold" })
                                @Html.TextBoxFor(m => m.EtkinlikAdi, new { @class = "form-control form-control-lg", placeholder = "Etkinlik adı girin" })
                                @Html.ValidationMessageFor(m => m.EtkinlikAdi, "", new { @class = "text-danger" })
                            </div>

                            <div class="mb-3">
                                @Html.LabelFor(m => m.OlusturulmaTarihi, new { @class = "form-label fw-bold" })
                                @Html.TextBoxFor(m => m.OlusturulmaTarihi, new
                                    {
                                        @class = "form-control form-control-lg",
                                        type = "date",
                                        min = DateTime.Now.ToString("yyyy-MM-dd")
                                    })

                                @Html.ValidationMessageFor(m => m.OlusturulmaTarihi, "", new { @class = "text-danger" })
                            </div>
                            <input type="hidden" name="kullaniciAdi" value="@ViewBag.KullaniciAdi" />
                            <div class="d-grid mt-4">
                                <button type="submit" class="btn btn-primary btn-lg shadow-sm">Kaydet</button>
                            </div>
                        }
                    </div>
                    <div class="card-footer text-center bg-light rounded-bottom-4">
                        <a href="@Url.Action("Index", "Etkinlikler", new { kullaniciAdi = ViewBag.KullaniciAdi })" class="text-decoration-none">&larr; Geri Dön</a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>