@model Etkinlik;
@{
	Layout=null;
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewBag.Title</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
    :root{
	--accent: #7c3aed;
	--accent-600: #6d28d9;
	--accent-700: #5b21b6;
	--bg: #f7f7fb;
	--card-bg: #ffffff;
	--muted: #64748b;
}

/* Sayfa zemini */
body{
	background: radial-gradient(1000px 600px at 10% -10%, #ffffff 0%, #f4f4ff 35%, transparent 36%) no-repeat,
	            radial-gradient(800px 500px at 110% 10%, #ffffff 0%, #f4f7ff 40%, transparent 41%) no-repeat,
	            var(--bg);
}

/* Kart görünümü */
.card{
	border: 1px solid rgba(124, 58, 237, .06);
	border-radius: 16px;
	background: linear-gradient(180deg, rgba(255,255,255,.86), rgba(255,255,255,.96));
	box-shadow: 0 8px 30px rgba(16, 24, 40, .08);
	backdrop-filter: saturate(140%) blur(2px);
	transition: transform .2s ease, box-shadow .2s ease;
}
.card:hover{
	transform: translateY(-2px);
	box-shadow: 0 12px 38px rgba(16, 24, 40, .12);
}

/* Başlık ve açıklama */
h1.h4, .h4{
	font-weight: 700;
	letter-spacing: .2px;
}
.muted{
	color: var(--muted);
}

/* Yükleme alanı */
.upload-area{
	border: 2px dashed #cbd5e1;
	border-radius: 16px;
	padding: 28px;
	background: #ffffff;
	cursor: pointer;
	text-align: center;
	transition: border-color .2s ease, background-color .2s ease, box-shadow .2s ease, transform .15s ease;
	position: relative;
}
.upload-area:hover{
	border-color: var(--accent);
	background: linear-gradient(180deg, #ffffff, #faf8ff);
	box-shadow: 0 8px 22px rgba(124, 58, 237, .08);
	transform: translateY(-1px);
}
/* Drag-over vurgusu (JS 'border-primary' ekliyor) */
.upload-area.border-primary{
	border-color: var(--accent) !important;
	box-shadow: 0 0 0 .25rem rgba(124, 58, 237, .18);
	background: linear-gradient(180deg, #ffffff, #f7f3ff);
}
/* Klavye odak */
.upload-area:focus-within{
	outline: none;
	border-color: var(--accent);
	box-shadow: 0 0 0 .25rem rgba(124, 58, 237, .2);
}
/* İkon */
.upload-area svg{
	color: var(--accent);
	opacity: .9;
	transition: transform .25s ease;
}
.upload-area:hover svg{
	transform: translateY(-2px) scale(1.03);
}

/* Önizleme alanı */
.preview{
	display: flex;
	flex-wrap: wrap;
	gap: 14px;
	justify-content: center;
	align-items: flex-start;
}
.preview img,
.preview video{
	width: 160px;
	height: 160px;
	max-width: 160px;
	max-height: 160px;
	border-radius: 14px;
	object-fit: cover;
	background: #f6f7fb;
	border: 1px solid rgba(2, 6, 23, .06);
	box-shadow: 0 8px 20px rgba(2, 6, 23, .06);
	transition: transform .18s ease, box-shadow .18s ease, filter .18s ease;
	animation: pop-in .2s ease-out both;
}
.preview img:hover,
.preview video:hover{
	transform: translateY(-2px) scale(1.02);
	box-shadow: 0 12px 28px rgba(2, 6, 23, .12);
}
.preview video{ outline: none; }
.preview img:focus-visible,
.preview video:focus-visible{
	outline: 3px solid rgba(124, 58, 237, .5);
	outline-offset: 2px;
}

/* Butonlar */
.btn-primary{
	background: linear-gradient(180deg, var(--accent), var(--accent-700));
	border: 0;
	box-shadow: 0 6px 16px rgba(124, 58, 237, .2);
}
.btn-primary:hover{
	background: linear-gradient(180deg, var(--accent-600), var(--accent-700));
	box-shadow: 0 8px 20px rgba(124, 58, 237, .28);
}
.btn-primary:focus{
	box-shadow: 0 0 0 .25rem rgba(124, 58, 237, .35);
}
.btn-outline-secondary{
	border-color: #cbd5e1;
	color: #0f172a;
	background: #fff;
}
.btn-outline-secondary:hover{
	background: #f8fafc;
	border-color: #94a3b8;
	box-shadow: 0 6px 14px rgba(2, 6, 23, .06);
}

/* Form hizalamaları */
.container .row.g-4{ row-gap: 28px; }

/* Küçük ekran önizleme boyutu */


/* Giriş kartı butonu */
.card .btn-success.btn-lg{
	box-shadow: 0 8px 18px rgba(22, 163, 74, .18);
}
.card .btn-success.btn-lg:hover{
	box-shadow: 0 10px 22px rgba(22, 163, 74, .24);
	transform: translateY(-1px);
	transition: transform .15s ease, box-shadow .2s ease;
}

/* Animasyon (Razor için @@) */

</style>

</head>
<body>
    <div class="container py-5">
        <div class="row g-4 justify-content-center">
            <!-- Medya Yükleme Kartı -->
            <div class="col-12 col-lg-7">
                <div class="card p-4 h-100">
                    <h1 class="h4 mb-3 text-center">@ViewBag.userNameSurname için Medya Yükle</h1>
                    <p class="muted mb-3 text-center">
                        Desteklenen türler: JPG, PNG, WEBP, GIF, MP4, WEBM, OGG (maks. 50MB / dosya)
                    </p>

                    <form id="uploadForm" action="/Etkinlikler/UploadFiles" method="post" enctype="multipart/form-data">
                        <input type="hidden" name="etkinlikId" value="@Model.EtkinlikId" />

                        <label for="media" class="upload-area" id="dropZone">
                            <div class="d-flex flex-column align-items-center gap-2">
                                <svg xmlns="http://www.w3.org/2000/svg" width="42" height="42" fill="currentColor" class="bi bi-cloud-arrow-up" viewBox="0 0 16 16">
                                    <path fill-rule="evenodd" d="M7.5 5.5a.5.5 0 0 1 1 0v3.793l1.146-1.147a.5.5 0 0 1 .708.708l-2 2-.007.007a.497.497 0 0 1-.7-.007l-2-2a.5.5 0 1 1 .708-.708L7.5 9.293V5.5z" />
                                    <path d="M4.406 3.342A5.53 5.53 0 0 1 8 2c2.69 0 4.923 2 5.166 4.579C14.758 6.804 16 8.137 16 9.773 16 11.569 14.502 13 12.687 13H11.5a.5.5 0 0 1 0-1h1.187C13.994 12 15 10.988 15 9.773c0-1.21-1.02-2.227-2.35-2.227a.5.5 0 0 1-.5-.5C12.15 4.846 10.328 3 8 3a4.53 4.53 0 0 0-3.594 1.77.5.5 0 1 1-.78-.628z" />
                                </svg>
                                <div>
                                    <span class="fw-semibold">Dosya(lar) seçin</span> veya sürükleyip bırakın
                                </div>
                                <input id="media" name="media" type="file" accept="image/*,video/*" multiple class="d-none" />
                            </div>
                        </label>

                        <div class="mt-3 d-flex gap-2 justify-content-center">
                            <button type="submit" class="btn btn-primary">Yükle</button>
                            <button type="button" id="clearBtn" class="btn btn-outline-secondary">Temizle</button>
                        </div>

                        <div id="validationArea" class="text-danger small mt-2 text-center" style="display:none;"></div>

                        <div class="preview mt-3 justify-content-center" id="preview" style="display:none;"></div>
                    </form>
                </div>
            </div>

            <!-- Giriş Yap Kartı -->
            <div class="col-12 col-lg-5">
                <div class="card p-4 h-100 d-flex flex-column justify-content-between">
                    <div>
                        <h2 class="h4 mb-3">Hesabın var mı?</h2>
                        <p class="muted mb-4">Medya yüklemek için giriş yapmana gerek yok; ancak medya içeriğine ve hesabına erişmek istersen aşağıdan devam edebilirsin.</p>
                    </div>
                    <div class="d-grid">
                        <a href="/Account/Login" class="btn btn-success btn-lg">Giriş Yap</a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    
    <script>
        (function () {
            const fileInput = document.getElementById('media');
            const dropZone = document.getElementById('dropZone');
            const preview = document.getElementById('preview');
            const validationArea = document.getElementById('validationArea');
            const clearBtn = document.getElementById('clearBtn');

            function resetPreview() {
                preview.style.display = 'none';
                preview.innerHTML = '';
                validationArea.style.display = 'none';
                validationArea.textContent = '';
            }

            function showError(msg) {
                validationArea.textContent = msg;
                validationArea.style.display = 'block';
            }

            function handleFiles(files) {
                resetPreview();
                if (!files || !files.length) return;
                const allowed = ['image/jpeg', 'image/png', 'image/webp', 'image/gif', 'video/mp4', 'video/webm', 'video/ogg'];
                const maxBytes = 50 * 1024 * 1024; // 50MB

                Array.from(files).forEach(file => {
                    if (!allowed.includes(file.type)) {
                        showError('Geçersiz dosya: ' + file.name);
                        return;
                    }
                    if (file.size > maxBytes) {
                        showError('Dosya boyutu 50MB limitini aşıyor: ' + file.name);
                        return;
                    }

                    const reader = new FileReader();
                    reader.onload = e => {
                        let el;
                        if (file.type.startsWith('video/')) {
                            el = document.createElement('video');
                            el.src = e.target.result;
                            el.controls = true;
                        } else {
                            el = document.createElement('img');
                            el.src = e.target.result;
                        }
                        preview.appendChild(el);
                        preview.style.display = 'flex';
                    };
                    reader.readAsDataURL(file);
                });
            }

            fileInput.addEventListener('change', (e) => handleFiles(e.target.files));

            ;['dragenter', 'dragover'].forEach(evt => dropZone.addEventListener(evt, (e) => {
                e.preventDefault();
                e.stopPropagation();
                dropZone.classList.add('border-primary');
            }));
            ;['dragleave', 'drop'].forEach(evt => dropZone.addEventListener(evt, (e) => {
                e.preventDefault();
                e.stopPropagation();
                dropZone.classList.remove('border-primary');
            }));
            dropZone.addEventListener('drop', (e) => {
                const files = e.dataTransfer.files;
                fileInput.files = files;
                handleFiles(files);
            });

            clearBtn.addEventListener('click', () => {
                fileInput.value = '';
                resetPreview();
            });
        })();
    </script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

