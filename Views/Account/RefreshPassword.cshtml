@{
    ViewData["Title"] = "Şifre Yenile";
    Layout = null;
}

<style>
    /* Reset basic browser styles */
    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    body {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        background: #0f172a;
        color: #f8fafc;
        line-height: 1.6;
    }

    /* Full-screen container for a centered card */
    .reset-bg {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1.5rem;
    }

    /* Main card container with a smooth, elevated look */
    .card {
        width: 100%;
        max-width: 420px;
        background: #1e293b;
        border-radius: 16px;
        padding: 2.5rem;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.25);
        border: 1px solid #334155;
        transition: transform 0.3s ease-in-out;
    }

        .card:hover {
            transform: translateY(-5px);
        }

        .card h2 {
            margin-bottom: 1.5rem;
            font-size: 1.75rem;
            font-weight: 600;
            text-align: center;
            color: #e2e8f0;
        }

    /* Form and input styling */
    .form-group {
        margin-bottom: 1.25rem;
    }

    label {
        display: block;
        margin-bottom: 0.5rem;
        font-size: 0.9rem;
        font-weight: 500;
        color: #cbd5e1;
    }

    input[type="password"] {
        width: 100%;
        padding: 0.75rem 1rem;
        border-radius: 10px;
        border: 2px solid #475569;
        background: #0f172a;
        color: #f8fafc;
        font-size: 1rem;
        transition: border-color 0.3s ease, box-shadow 0.3s ease;
    }

        input[type="password"]:focus {
            border-color: #6366f1;
            outline: none;
            box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.2);
        }

    /* Button styles with a hover effect */
    .btn {
        width: 100%;
        padding: 0.85rem;
        border: none;
        border-radius: 10px;
        background: #6366f1;
        color: white;
        font-weight: 600;
        font-size: 1rem;
        cursor: pointer;
        transition: background-color 0.3s ease, transform 0.1s ease;
    }

        .btn:hover {
            background: #4f46e5;
        }

        .btn:active {
            transform: scale(0.99);
        }

    /* Validation message styling */
    .validation-message {
        color: #ef4444; /* A more prominent red for errors */
        font-size: 0.85rem;
        margin-top: 0.5rem;
        display: block;
        text-align: center;
    }
</style>
<div class="reset-bg">
    <div class="card">
        <h2>Şifre Yenile</h2>
        <form action="/Account/RefreshPassword" method="post">
            
            <input  type="hidden" name="username" value="@ViewBag.username"/>
            <input  type="hidden" name="token" value="@ViewBag.Token"/>
            <div class="form-group">
                <label for="NewPassword">Yeni Şifre</label>
                <input type="password" id="NewPassword" name="NewPassword" placeholder="En az 8 karakter" required minlength="8" />
            </div>

            <div class="form-group">
                <label for="ConfirmNewPassword">Yeni Şifre (Tekrar)</label>
                <input type="password" id="ConfirmNewPassword" name="ConfirmNewPassword" placeholder="Tekrar" required minlength="8" />
            </div>

            <div class="form-group">
                <span id="errorMsg" class="validation-message"></span>
            </div>

            <button type="submit" class="btn">Şifreyi Yenile</button>
        </form>
    </div>
</div>

<script>
    const form = document.querySelector('form');
    const newPwd = document.getElementById('NewPassword');
    const confirmPwd = document.getElementById('ConfirmNewPassword');
    const errorMsg = document.getElementById('errorMsg');

    form.addEventListener('submit', function (e) {
        if (newPwd.value !== confirmPwd.value) {
            e.preventDefault();
            errorMsg.textContent = 'Şifreler uyuşmuyor.';
            confirmPwd.focus();
        }
    });
</script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    document.addEventListener("DOMContentLoaded", function() {

    @* Başarılı mesaj *@
    @if (TempData["Success"] != null)
    {
        <text>
                Swal.fire({
                    icon: 'success',
                title: 'Başarılı!',
                text: 'Şifre Yenileme İşlemi Başarılı',
                confirmButtonText: 'Tamam'
                }).then((result) => {
                    if (result.isConfirmed) {
                    window.location.href = '/Account/Login';
                    }
                });
        </text>
    }

    @if (ViewBag.TokenExpired != null && ViewBag.TokenExpired == true)
    {
        <text>
                    Swal.fire({
                        icon: 'error',
                    title: 'Hata!',
                    text: 'Şifre yenileme süresi dolmuş.',
                    confirmButtonText: 'Tamam'
                             }).then((result) => {
                            if (result.isConfirmed) {
                        window.location.href = '/Account/ForgotPassword';
                            }
                        });
        </text>
    }
            });

</script>

