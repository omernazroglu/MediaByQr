@{
    Layout = null;
}
@model Kullanici;

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Giriş Yap</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Poppins', sans-serif;
            background: linear-gradient(135deg, #6a11cb, #2575fc);
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
        }

        .card {
            border-radius: 20px;
            padding: 2.5rem;
            max-width: 400px;
            width: 100%;
            background-color: #ffffff;
            box-shadow: 0 20px 40px rgba(0,0,0,0.15);
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

            .card:hover {
                transform: translateY(-5px);
                box-shadow: 0 25px 50px rgba(0,0,0,0.2);
            }

        h3 {
            text-align: center;
            margin-bottom: 1.5rem;
            color: #6a11cb;
            font-weight: 700;
        }

        .form-label {
            font-weight: 500;
            color: #333;
        }

        .form-control {
            border-radius: 12px;
            padding: 0.75rem 1rem;
            border: 1px solid #ccc;
            transition: border 0.3s ease, box-shadow 0.3s ease;
        }

            .form-control:focus {
                border-color: #6a11cb;
                box-shadow: 0 0 0 0.2rem rgba(106,17,203,0.25);
                outline: none;
            }

        .btn-primary {
            background: linear-gradient(45deg, #6a11cb, #2575fc);
            border: none;
            border-radius: 50px;
            padding: 12px 0;
            font-weight: 600;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

            .btn-primary:hover {
                transform: scale(1.05);
                box-shadow: 0 10px 20px rgba(0,0,0,0.2);
            }

        .text-center a {
            display: inline-block;
            margin-top: 0.5rem;
            color: #6a11cb;
            text-decoration: none;
            transition: color 0.3s ease;
        }

            .text-center a:hover {
                color: #2575fc;
                text-decoration: underline;
            }

        .btn-description {
            font-size: 0.85rem;
            color: #555;
            margin-bottom: 1rem;
            text-align: center;
        }
    </style>
</head>
<body>
    <div class="card shadow">
        <h3>Giriş Yap</h3>
        <form method="post" action="/Account/Login">
            <div class="mb-3">
                <label for="Email" class="form-label">Kullanıcı Adı</label>
                <input type="text" class="form-control" asp-for="KullaniciAdi" required />
            </div>
            <div class="mb-3">
                <label for="Password" class="form-label">Şifre</label>
                <input type="password" class="form-control" asp-for="SifreHash" required />
            </div>

            <button type="submit" class="btn btn-primary w-100">Giriş Yap</button>
        </form>
        <div class="text-center mt-3">
            <a href="/Account/ForgotPassword">Şifremi Unuttum</a>
        </div>
        <div class="text-center mt-2">
            <a href="/Account/Create">Hesabın yok mu? Kayıt Ol</a>
        </div>
    </div>

    <!-- SweetAlert CDN -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        // Başarılı giriş mesajı
        @if (TempData["LoginSuccess"] != null)
        {
            @:Swal.fire({
            @:icon: 'success',
            @:title: 'Başarılı!',
            @:text: 'Giriş Başarılı',
            @:confirmButtonText: 'Tamam'
            @:}).then((result) => {
            @:    if (result.isConfirmed) {
            @:window.location.href = '/Etkinlikler/?kullaniciAdi=' + encodeURIComponent('@(TempData["KullaniciAdi"])');
            @:    }
            @:});
        }

            // Hatalı giriş mesajı
        @if (TempData["LoginError"] != null)
        {
            @:Swal.fire({
            @:icon: 'error',
            @:title: 'Hata!',
            @:text: 'Kullanıcı adı veya şifre hatalı',
            @:confirmButtonText: 'Tamam'
            @:});
        }
    </script>
</body>
</html>
