@{
   Layout = null;
}
@model Kullanici

<!doctype html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>kullanıcı bilgileri</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <style>
        /* Body ve Container Ayarları */
        body {
            background-color: #e9eff5; /* Açık mavi-gri arka plan */
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            color: #495057; /* Koyu gri metin rengi */
            padding: 40px;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
        }

        .action-buttons {
            gap: 1rem;
        }   

        .btn-profile, .btn-logout, .btn-new-event {
            border-radius: 50px;
            font-weight: 600;
            transition: all 0.3s ease;
        }

        .btn-profile {
            background-color: #ffffff;
            color: #4f33ff;
            border: 2px solid #4f33ff;
        }

            .btn-profile:hover {
                background-color: #4f33ff;
                color: #ffffff;
                transform: translateY(-3px);
                box-shadow: 0 4px 12px rgba(79, 51, 255, 0.3);
            }

        .btn-logout {
            background-color: #ffffff;
            color: #dc3545;
            border: 2px solid #dc3545;
        }

            .btn-logout:hover {
                background-color: #dc3545;
                color: #ffffff;
                transform: translateY(-3px);
                box-shadow: 0 4px 12px rgba(220, 53, 69, 0.3);
            }

        .btn-new-event {
            background-color: #4f33ff;
            color: #ffffff;
            border: none;
        }

            .btn-new-event:hover {
                background-color: #3d26cc;
                transform: translateY(-3px);
                box-shadow: 0 6px 15px rgba(79, 51, 255, 0.4);
            }
        .container {
            max-width: 600px;
            width: 100%;
            padding: 0;
        }

        /* Başlık */
        h3 {
            color: #2c3e50;
            font-weight: 700;
            text-align: center;
            margin-bottom: 30px;
            letter-spacing: 1px;
        }

        /* Kart (Card) Stili */
        .card {
            background-color: #ffffff;
            border-radius: 15px;
            padding: 30px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08); /* Yumuşak gölge */
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            border: none;
        }

            .card:hover {
                transform: translateY(-8px);
                box-shadow: 0 15px 40px rgba(0, 0, 0, 0.12); /* Daha belirgin gölge */
            }

        /* Tablo (Table) Stili */
        .table {
            margin-bottom: 20px;
        }

        th {
            font-weight: 600;
            color: #6c757d; /* Orta gri başlık metni */
            border-top: none !important;
            padding: 15px 0;
        }

        td {
            color: #34495e; /* Koyu gri veri metni */
            font-weight: 500;
            border-top: none !important;
            padding: 15px 0;
        }

        .table-striped > tbody > tr:nth-of-type(odd) {
            background-color: #f8f9fa; /* Hafif çizgili arka plan */
        }

        /* Buton Stilleri */
        .btn {
            border-radius: 50px; /* Hap şeklinde butonlar */
            font-weight: 600;
            padding: 12px 25px;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            justify-content: center;
        }

            .btn i {
                margin-right: 8px;
                font-size: 1.1em;
            }

        .btn-primary {
            background-color: #3498db; /* Mavi renk tonu */
            border-color: #2980b9;
            color: #fff;
        }

            .btn-primary:hover {
                background-color: #2980b9;
                border-color: #24719c;
            }

        .btn-outline-secondary {
            border-color: #95a5a6;
            color: #555;
        }

            .btn-outline-secondary:hover {
                background-color: #ecf0f1;
                color: #2c3e50;
                border-color: #95a5a6;
            }

        /* Buton Grubu */
        .d-flex.justify-content-end.mt-3 {
            gap: 15px;
        }

        /* Modal Stili */
        .modal-content {
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
            border: none;
        }

        .modal-header {
            border-bottom: none;
            padding: 20px 25px 0;
        }

        .modal-title {
            font-weight: 700;
            color: #2c3e50;
        }

        .modal-body .form-label {
            font-weight: 500;
            color: #555;
        }

        .modal-footer {
            border-top: none;
            padding: 10px 25px 25px;
        }

        .form-control {
            border-radius: 10px;
            padding: 12px;
        }

        .btn-success {
            background-color: #27ae60;
            border-color: #229954;
            font-weight: 600;
        }

            .btn-success:hover {
                background-color: #229954;
                border-color: #1e8449;
            }

        /* Mobil Uyumlu Tasarım */
        @@media (max-width: 576px) {
            body {
                padding: 10px;
            }

            h3 {
                font-size: 1.5rem;
            }

            .card {
                padding: 20px;
                border-radius: 0;
            }

            .d-flex.justify-content-end.mt-3 {
                flex-direction: column;
                gap: 10px;
            }

            .btn {
                width: 100%;
                margin: 0 !important;
            }
        }
    </style>
</head>
<body>

    <
    <div class="action-buttons position-absolute top-0 end-0 m-3 d-flex">
        <a href="@Url.Action("Index","Etkinlikler", new { kullaniciAdi = Model.KullaniciAdi })"
           class="btn btn-profile d-flex align-items-center me-2">
            <i class="bi bi-arrow-left-circle"></i>
            Etkinlikler'e Geri Dön
        </a>

        <a href="/Home/Index" class="btn btn-logout d-flex align-items-center">
            <i class="bi bi-box-arrow-right me-2"></i>
            Çıkış Yap
        </a>
    </div>

      
    <div class="container py-4">
        <h3 class="mb-4">Kullanıcı Bilgileri</h3>

        <div class="card shadow-sm p-3 mb-4">
            <table class="table table-borderless table-striped align-middle">
                <tbody>
                    <tr>
                        <th style="width: 150px;">Ad Soyad:</th>
                        <td>@Model.Ad_Soyad</td>
                    </tr>
                    <tr>
                        <th>Kullanıcı Adı:</th>
                        <td>@Model.KullaniciAdi</td>
                    </tr>
                   
                </tbody>
            </table>

            <div class="d-flex justify-content-end mt-3">
                <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#changeInformationModal">
                    <i class="bi bi-pencil-square"></i> Bilgileri Düzenle
                </button>

                <!-- Şifre Değiştir Butonu -->
                <button type="button" class="btn btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#changePasswordModal">
                    <i class="bi bi-key-fill"></i> Şifre Değiştir
                </button>
            </div>
        </div>
    </div>

    <!-- Şifre Değiştir Modal -->
    <div class="modal fade" id="changePasswordModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content p-4">
                <div class="modal-header border-0">
                    <h5 class="modal-title">Şifre Değiştir</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form method="post" action="@Url.Action("ChangePassword", "Account")" onsubmit="return checkPasswordChange()">
                    <div class="modal-body">
                        <input type="hidden" name="kullaniciAdi" value="@Model.KullaniciAdi"/>
                        <div class="mb-3">
                            <label class="form-label">Eski Şifre</label>
                            <input type="password" class="form-control" name="OldPassword" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Yeni Şifre</label>
                            <input type="password" class="form-control" id="NewPassword" name="NewPassword" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Yeni Şifre Tekrar</label>
                            <input type="password" class="form-control" id="ConfirmNewPassword" name="ConfirmNewPassword" required />
                        </div>
                    </div>
                    <div class="modal-footer border-0">
                        <button type="submit" class="btn btn-success w-100">Şifreyi Güncelle</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

       <!-- Bilgi Güncelle Modal -->
    <div class="modal fade" id="changeInformationModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content p-4">
                <div class="modal-header border-0">
                    <h5 class="modal-title">Bilgileri Güncelle</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form method="post" action="@Url.Action("ChangeInformation", "Account")" onsubmit="return checkUserNameChange()">
                    <div class="modal-body">
                        <input type="hidden" name="kullaniciId" value="@Model.KullaniciId"/>
                        <div class="mb-3">
                            <label class="form-label">Ad Soyad</label>
                            <input type="text" class="form-control" name="Ad_Soyad" required placeholder="@Model.Ad_Soyad" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Kullanıcı Adı</label>
                            <input type="text" class="form-control" id="KullaniciAdi" name="KullaniciAdi" required @Model.KullaniciAdi />
                        </div>
                       
                    </div>
                    <div class="modal-footer border-0">
                        <button type="submit" class="btn btn-success w-100">Bilgileri Güncelle</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    














    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        function checkPasswordChange() {
            const newPass = document.getElementById("NewPassword").value;
            const confirm = document.getElementById("ConfirmNewPassword").value;

            if (newPass.length < 8) {
                Swal.fire({
                    icon: 'error',
                    title: 'Hata!',
                    text: 'Yeni şifre en az 8 karakter olmalı!'
                });
                return false;
            }

            if (newPass !== confirm) {
                Swal.fire({
                    icon: 'error',
                    title: 'Hata!',
                    text: 'Yeni şifreler aynı olmalı!'
                });
                return false;
            }

            return true;
        }
        @if (TempData["Success"] != null)
        {
            @:Swal.fire({
            @:icon: 'success',
            @:title: 'Başarılı!',
            @:text: 'Şifre Başarıyla Değiştirildi',
            @:confirmButtonText: 'Tamam'
            @:}).then((result) => {
            @:    if (result.isConfirmed) {
            @: var changePasswordModal = bootstrap.Modal.getInstance(document.getElementById('changePasswordModal'));
            @:  changePasswordModal.hide();
            @:    }
            @:});
        }

            // Hatalı giriş mesajı
        @if (TempData["Error"] != null)
        {
            @:Swal.fire({
            @:icon: 'error',
            @:title: 'Hata!',
            @:text: 'Eski Şifre Hatalı',
            @:confirmButtonText: 'Tamam'
            @:});
        }


          @if (TempData["InformationSuccess"] != null)
        {
            @:Swal.fire({
            @:icon: 'success',
            @:title: 'Başarılı!',
            @:text: 'Bilgiler Başarıyla Güncellendi',
            @:confirmButtonText: 'Tamam'
            @:});
        }

            // Hatalı giriş mesajı
        @if (TempData["InformationFalse"] != null)
        {
            @:Swal.fire({
            @:icon: 'error',
            @:title: 'Hata!',
            @:text: 'Aynı Kullanıcı Adına Sahip Başka Bir Kullanıcı Var',
            @:confirmButtonText: 'Tamam'
            @:});
        }



    </script>

</body>
</html>
