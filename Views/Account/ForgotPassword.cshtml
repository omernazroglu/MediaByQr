@{
    ViewData["Title"] = "Şifremi Unuttum";
    Layout=null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        /* Genel Stil */
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: #f0f2f5;
            color: #495057;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            padding: 20px; /* Mobil uyum için basit bir padding */
        }

        /* Ana Kart Stili */
        .card {
            border: none;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
            background-color: #fff;
            padding: 2.5rem;
            width: 100%;
            max-width: 450px;
            transition: transform 0.3s ease-in-out, box-shadow 0.3s ease-in-out;
        }

            .card:hover {
                transform: translateY(-5px);
                box-shadow: 0 15px 40px rgba(0, 0, 0, 0.15);
            }

        /* Başlık Stili */
        h3 {
            font-weight: 700;
            color: #34495e;
            letter-spacing: 1px;
            margin-bottom: 25px;
            text-align: center;
        }

        /* Form Elemanları */
        .form-label {
            font-weight: 600;
            color: #555;
            margin-bottom: 8px;
        }

        .form-control {
            border-radius: 10px;
            border: 1px solid #e0e0e0;
            padding: 12px 15px;
            box-shadow: none !important;
            transition: border-color 0.3s ease;
        }

            .form-control:focus {
                border-color: #5d9cec;
            }

        /* Buton Stilleri */
        .btn-primary {
            background-color: #5d9cec;
            border: none;
            border-radius: 10px;
            font-weight: 600;
            padding: 12px;
            transition: background-color 0.3s ease;
        }

            .btn-primary:hover {
                background-color: #4a89d7;
            }

        /* Metin Mesajları ve Bağlantılar */
        #lblSonuc {
            min-height: 20px;
            font-size: 0.9em;
            padding-top: 5px;
        }

        a {
            color: #5d9cec;
            text-decoration: none;
            font-weight: 500;
            transition: color 0.3s ease;
        }

            a:hover {
                color: #4a89d7;
                text-decoration: underline;
            }
    </style>
</head>
<body class="bg-light">
    <div class="container">
        <div class="row justify-content-center align-items-center vh-100">
            <div class="col-md-6">
                <div class="card shadow-lg p-4">
                    <h3 class="text-center mb-4">🔐 Şifre Sıfırlama</h3>

                    <form method="post" action="/Account/ForgotPassword">
                        <div class="mb-3">
                            <label for="UserName" class="form-label">Kullanıcı Adı</label>
                            <input type="text" class="form-control" name="kullaniciAdi" id="UserName" required />
                        </div>

                        <div class="mb-3">
                            <label for="Email" class="form-label">Email</label>
                            <input type="email" class="form-control" name="Email" id="Email" required />
                        </div>

                        <div class="d-grid mb-3">
                            <button type="submit" class="btn btn-primary btn-lg">📩 Bağlantı Gönder</button>
                        </div>

                        <div class="text-center">
                            <div id="lblSonuc" class="fw-bold text-danger">
                                @ViewData["ErrorMessage"] <!-- Server tarafında buraya mesaj gönderebilirsin -->
                            </div>
                        </div>

                        <div class="text-center mt-3">
                            <a href="/Account/Login">← Giriş ekranına dön</a>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</body>
</html>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
    document.addEventListener("DOMContentLoaded", function () {
    @if (TempData["MailSuccess"] != null)
    {
        <text>
                Swal.fire({
                    icon: 'success',
                title: 'Gönderildi',
                text: 'Şifre Yenileme Bağlantısı Mail Hesabınıza Gönderildi',
                confirmButtonText: 'Tamam'

                        });
        </text>
    }
    @if (TempData["UserFalse"] != null)
    {
        <text>
                Swal.fire({
                    icon: 'error',
                title: 'Başarısız',
                text: 'Bu Kullanıcı Adına Sahip Kullanıcı Bulunamadı',
                confirmButtonText: 'Tamam'

                        });
        </text>
    }
        }); 

</script>