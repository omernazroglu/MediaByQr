@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

    <style>
        :root {
            --primary-color: #6a11cb;
            --secondary-color: #2575fc;
            --card-bg: #ffffff;
            --text-color: #333;
            --light-text: #6c757d;
        }

        body {
            font-family: 'Poppins', sans-serif;
            background: linear-gradient(135deg, #6a11cb, #2575fc, #42e695, #3bb2b8);
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--text-color);
        }

        .hero-card {
            background: var(--card-bg);
            padding: 3rem 2rem;
            border-radius: 25px;
            box-shadow: 0 25px 50px rgba(0,0,0,0.2);
            text-align: center;
            max-width: 520px;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

            .hero-card:hover {
                transform: translateY(-8px);
                box-shadow: 0 35px 60px rgba(0,0,0,0.25);
            }

            .hero-card h1 {
                font-weight: 700;
                color: var(--primary-color);
                margin-bottom: 1rem;
                font-size: 2.2rem;
            }

            .hero-card p {
                font-weight: 400;
                color: var(--light-text);
                margin-bottom: 2rem;
                font-size: 1rem;
            }

        .btn-custom {
            font-weight: 600;
            letter-spacing: 1px;
            padding: 15px 25px;
            border-radius: 50px;
            transition: all 0.3s ease;
            width: 100%;
            margin-bottom: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

        .btn-primary-custom {
            background-image: linear-gradient(45deg, var(--primary-color), var(--secondary-color));
            border: none;
            color: white;
        }

            .btn-primary-custom:hover {
                transform: scale(1.05);
                background-image: linear-gradient(45deg, var(--secondary-color), var(--primary-color));
            }

        .btn-outline-custom {
            background: transparent;
            border: 2px solid var(--primary-color);
            color: var(--primary-color);
        }

            .btn-outline-custom:hover {
                background: var(--primary-color);
                color: white;
                transform: scale(1.05);
            }

        .btn-description {
            font-size: 0.85rem;
            color: var(--light-text);
            margin-bottom: 1.5rem;
        }

        .icon {
            font-size: 1.2rem;
        }
    </style>
</head>
<body>
    <div class="hero-card">
        <h1>Etkinlik Fotoğraflarını Hızla Yükleyin</h1>
        <p>QR kod ile fotoğraf yüklemek artık çok kolay. Etkinliklere katılın, anılarınızı paylaşın ve saklayın.</p>

        <a href="/Account/Login" class="btn btn-primary-custom btn-custom">
            <i class="fa fa-right-to-bracket icon"></i> Giriş Yap
        </a>
        <div class="btn-description">Mevcut hesabınızla giriş yapın ve fotoğrafları keşfetmeye başlayın.</div>

        <a href="/Account/Create" class="btn btn-outline-custom btn-custom">
            <i class="fa fa-user-plus icon"></i> Hesap Oluştur
        </a>
        <div class="btn-description">Henüz hesabınız yok mu? Hemen kayıt olun ve anıları biriktirin.</div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
